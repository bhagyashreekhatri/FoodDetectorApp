# This file contains the fastlane.tools configuration
# You can find the documentation at https://docs.fastlane.tools
#
# For a list of all available actions, check out
#
#     https://docs.fastlane.tools/actions
#
# For a list of all available plugins, check out
#
#     https://docs.fastlane.tools/plugins/available-plugins
#

# Uncomment the line if you want fastlane to automatically update itself
# update_fastlane

default_platform(:ios)
platform :ios do
  # Use xcbeautify (brew) instead of xcpretty (ruby gem)
  ENV["FASTLANE_XCODEBUILD_FORMATTER"] = "xcbeautify"

  desc "Run tests on iOS Simulator"
  lane :tests do
    scan(
      scheme: "FoodDetectorApp",
      project: "FoodDetectorApp.xcodeproj",
      device: "iPhone 15",
      clean: true
    )
  end

  desc "Build/Archive for iOS (CI build)"
  lane :build do
    gym(
      scheme: "FoodDetectorApp",
      project: "FoodDetectorApp.xcodeproj",
      configuration: "Release",
      destination: "generic/platform=iOS",   # ✅ THIS FIXES UIKit error
      clean: true,
      skip_package_ipa: true,
      skip_codesigning: true,                # ✅ CI build without signing
      skip_archive: true
    )
  end
end